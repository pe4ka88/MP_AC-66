<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvTitlePath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/path_screen_title"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvInfoPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/fio_group"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvAuthorPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/author_text"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/etRouteFrom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:hint="@string/hint_from"
            android:inputType="textCapSentences"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etRouteTo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_to"
            android:inputType="textCapSentences"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etCity"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_city"
            android:inputType="textCapWords"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etStartStreet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_start_street"
            android:inputType="textCapWords"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etEndStreet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:hint="@string/hint_end_street"
            android:inputType="textCapWords"
            android:maxLines="1" />

        <EditText
            android:id="@+id/etComment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="top|start"
            android:hint="@string/hint_comment"
            android:inputType="textCapSentences|textMultiLine"
            android:minLines="3" />

        <Button
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="@string/ok" />

        <Button
            android:id="@+id/btnOpenTaskPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/author_button" />

        <Button
            android:id="@+id/btnBackToMainPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/back_to_main" />

    </LinearLayout>
</ScrollView>
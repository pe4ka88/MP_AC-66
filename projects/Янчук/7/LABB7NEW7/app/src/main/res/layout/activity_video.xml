<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <Button
        android:id="@+id/btnSelectVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выбрать видео" />

    <TextView
        android:id="@+id/txtVideoName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Файл не выбран"
        android:textSize="18sp"
        android:layout_below="@id/btnSelectVideo"
        android:paddingTop="12dp" />

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="250dp"
        android:layout_below="@id/txtVideoName"
        android:layout_marginTop="16dp" />

    <SeekBar
        android:id="@+id/videoSeekBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/videoView"
        android:paddingTop="12dp" />

    <!-- Панель управления -->
    <LinearLayout
        android:id="@+id/videoControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/videoSeekBar"
        android:paddingTop="16dp"
        android:visibility="gone">

        <!-- Верхний ряд: Play / Pause / Stop -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:weightSum="3">

            <Button
                android:id="@+id/btnPlayVideo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Play" />

            <Button
                android:id="@+id/btnPauseVideo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Pause" />

            <Button
                android:id="@+id/btnStopVideo"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Stop" />
        </LinearLayout>

        <!-- Нижний ряд: перемотка -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingTop="12dp"
            android:weightSum="2">

            <Button
                android:id="@+id/btnBack10"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="-10 сек" />

            <Button
                android:id="@+id/btnForward10"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="+10 сек" />
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>

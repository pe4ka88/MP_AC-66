<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp">

    <TextView
        android:id="@+id/tvAuthorTop"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ЛР №1 | Лысюк Ростислав | АС-66"
        android:textSize="16sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tvTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Время: 00:00"
        android:textSize="18sp"
        android:layout_marginTop="6dp"/>

    <TextView
        android:id="@+id/tvBest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Рекорд: --:--"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/tvPairs"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Осталось пар: 8"
        android:textSize="16sp"/>

    <TextView
        android:id="@+id/tvMoves"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ходов: 0"
        android:textSize="16sp"/>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvBoard"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"/>

    <Button
        android:id="@+id/btnRestart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Перезапустил Лысюк"/>

    <TextView
        android:id="@+id/tvAuthorBottom"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Разработал Лысюк Ростислав"
        android:textAlignment="center"
        android:paddingTop="8dp"
        android:textSize="14sp"/>

</LinearLayout>

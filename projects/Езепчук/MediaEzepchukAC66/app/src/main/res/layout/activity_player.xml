<RelativeLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фоновое изображение -->
    <ImageView
        android:id="@+id/bgImage"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_media4"
        android:scaleType="centerCrop"
        android:contentDescription="Фон"/>

    <!-- Полупрозрачный оверлей для контраста -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#66000000"/>

    <!-- Основной контейнер -->
    <LinearLayout
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center_horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <!-- Заголовок -->
        <TextView
            android:id="@+id/titleText"
            android:text="Аудио / Видео"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:layout_marginBottom="24dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>

        <!-- Карточка плеера -->
        <LinearLayout
            android:id="@+id/cardContainer"
            android:orientation="vertical"
            android:background="@drawable/card_background_2"
            android:padding="16dp"
            android:elevation="8dp"
            android:clipToOutline="true"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <!-- Плеер (скрыт по умолчанию) -->
            <com.google.android.exoplayer2.ui.PlayerView
                android:id="@+id/playerView"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                app:use_controller="true"
                android:background="#000000"
                android:clipToOutline="true"
                android:visibility="gone"/>

            <!-- Подпись -->
            <TextView
                android:id="@+id/playerLabel"
                android:text="Предпросмотр аудио / видео"
                android:textStyle="bold"
                android:textSize="16sp"
                android:textColor="#FFFFFF"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="8dp"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Кнопка выбора файла -->
            <ImageButton
                android:id="@+id/btnSelectFile"
                android:src="@android:drawable/ic_media_play"
                android:background="@drawable/button_image_background_3"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="12dp"
                android:scaleType="center"
                android:contentDescription="Выбрать аудио / видео"/>
        </LinearLayout>

    </LinearLayout>
    <TextView
        android:id="@+id/copyrightText"
        android:text="© 2026 Езепчук А.С. АС-66"
        android:textSize="12sp"
        android:textColor="#DDFFFFFF"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:layout_marginBottom="12dp"
        android:alpha="0.8"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</RelativeLayout>
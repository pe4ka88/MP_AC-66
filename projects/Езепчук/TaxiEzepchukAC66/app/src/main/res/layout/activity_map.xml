<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:windowBackground">

    <!-- Карта -->
    <com.yandex.mapkit.mapview.MapView
        android:id="@+id/mapview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Верхняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="@color/panel_dark">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <AutoCompleteTextView
                android:id="@+id/etAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:hint="Поиск адреса(ищет Езепчук А.С. лично)"
                android:textColor="@color/text_dark"
                android:textColorHint="#AAAAAA" />

            <Button
                android:id="@+id/btnGps"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="4dp">

            <TextView
                android:id="@+id/tvPickup"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Откуда(ЕАС):"
                android:textColor="@color/text_dark"
                android:padding="4dp"/>

            <TextView
                android:id="@+id/tvDropoff"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Куда(ЕАС):"
                android:textColor="@color/text_dark"
                android:padding="4dp"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Нижняя панель -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="117dp"
        android:layout_gravity="bottom"
        android:background="@color/panel_dark"
        android:orientation="horizontal"
        android:padding="12dp">

        <Button
            android:id="@+id/btnPickup"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ОТКУДА" />

        <Button
            android:id="@+id/btnDropoff"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="КУДА" />

        <Button
            android:id="@+id/btnDone"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Готово" />

    </LinearLayout>

    <!-- Copyright -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="© 2026 Езепчук А.С."
        android:textSize="11sp"
        android:textColor="#AAAAAA"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="4dp"/>

</FrameLayout>
<?xml version="1.0" encoding="utf-8"?>

<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F6FA">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Верхняя панель с кнопкой назад и заголовком -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="20dp">

            <!-- Кнопка назад -->
            <ImageButton
                android:id="@+id/btnBack"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_gravity="center"
                android:background="@android:color/transparent"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Back"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:scaleType="fitCenter"
                android:adjustViewBounds="true"
                />
            <!-- Заголовок -->
            <TextView
                android:id="@+id/textHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Профиль пользователя"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#222"
                android:layout_centerInParent="true"/>
        </RelativeLayout>

        <!-- Иконка профиля -->
        <ImageView
            android:id="@+id/profileIcon"
            android:layout_width="110dp"
            android:layout_height="110dp"
            android:layout_gravity="center"
            android:src="@drawable/icon_profil"
            android:background="@drawable/bg_circle_button"
            android:padding="20dp"
            android:layout_marginBottom="20dp"/>

        <!-- Имя -->
        <EditText
            android:id="@+id/editName"
            android:hint="Имя"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="12dp"/>

        <!-- Email -->
        <EditText
            android:id="@+id/editEmail"
            android:hint="Email"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginTop="10dp"/>

        <!-- Пароль -->
        <EditText
            android:id="@+id/editPassword"
            android:hint="Пароль"
            android:inputType="textPassword"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_input"
            android:padding="12dp"
            android:layout_marginTop="10dp"/>

        <!-- Кнопка входа -->
        <Button
            android:id="@+id/btnLogin"
            android:text="Войти"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:background="@drawable/bg_button"
            android:textColor="#FFFFFF"/>

        <!-- Блок профиля -->
        <LinearLayout
            android:id="@+id/profileLayout"
            android:visibility="gone"
            android:orientation="vertical"
            android:layout_marginTop="24dp"
            android:padding="16dp"
            android:background="@drawable/bg_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- Имя -->
            <TextView
                android:id="@+id/textProfileName"
                android:textSize="20sp"
                android:textStyle="bold"
                android:text="Имя"
                android:textColor="#222"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Email -->
            <TextView
                android:id="@+id/textProfileEmail"
                android:text="Email"
                android:textColor="#555"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"/>

            <!-- Баланс -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Баланс"
                android:textStyle="bold"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/textBalance"
                android:text="$100"
                android:textSize="20sp"
                android:textColor="#4CAF50"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>

            <!-- Адрес доставки -->
            <EditText
                android:id="@+id/editAddress"
                android:hint="Адрес доставки"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:layout_marginTop="12dp"/>

            <Button
                android:id="@+id/btnSaveAddress"
                android:text="Сохранить адрес"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/bg_button"
                android:textColor="#FFFFFF"/>

            <!-- Кнопка выхода -->
            <Button
                android:id="@+id/btnLogout"
                android:text="Выйти"
                android:layout_marginTop="16dp"
                android:background="@drawable/bg_button_red"
                android:textColor="#FFFFFF"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>

        </LinearLayout>

        <!-- Копирайт -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="© Алексей Езепчук, 2026"
            android:textAlignment="center"
            android:textSize="12sp"
            android:textColor="#777777"
            android:layout_marginTop="24dp"/>

    </LinearLayout>

</ScrollView>
<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Фон -->
    <solid android:color="#FFFFFF"/>

    <!-- Скругление -->
    <corners android:radius="16dp"/>

    <!-- Обводка -->
    <stroke
        android:width="2dp"
        android:color="#6A5ACD"/>

    <!-- Внутренние отступы -->
    <padding
        android:left="14dp"
        android:top="12dp"
        android:right="14dp"
        android:bottom="12dp"/>
</shape>

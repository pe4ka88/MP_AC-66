<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_theme_light_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBarLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/tbank_yellow"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:elevation="0dp"
            app:title="Пользователи"
            app:titleTextColor="@color/tbank_black"
            app:titleTextAppearance="@style/TextAppearance.TBank.Toolbar" />

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="16dp"
            android:paddingBottom="16dp">

            <!-- НОВАЯ ПАНЕЛЬ: Выбор типа запроса -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="📡 Тип запроса"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/tbank_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <com.google.android.material.chip.ChipGroup
                        android:id="@+id/requestTypeChipGroup"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:singleSelection="true"
                        app:selectionRequired="true">

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipUsers"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="👥 Пользователи"
                            android:checked="true"
                            app:chipBackgroundColor="@color/chip_background_color"
                            app:chipStrokeColor="@color/tbank_yellow" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipPosts"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="📝 Посты"
                            app:chipBackgroundColor="@color/chip_background_color"
                            app:chipStrokeColor="@color/tbank_yellow" />

                        <com.google.android.material.chip.Chip
                            android:id="@+id/chipComments"
                            style="@style/Widget.Material3.Chip.Filter"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="💬 Комментарии"
                            app:chipBackgroundColor="@color/chip_background_color"
                            app:chipStrokeColor="@color/tbank_yellow" />

                    </com.google.android.material.chip.ChipGroup>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- НОВАЯ ПАНЕЛЬ: Управление отображением -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="🎨 Вид отображения"
                        android:textAppearance="?attr/textAppearanceTitleMedium"
                        android:textColor="@color/tbank_black"
                        android:textStyle="bold"
                        android:layout_marginBottom="12dp" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/viewListButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="Список"
                            android:textSize="14sp"
                            app:icon="@android:drawable/ic_menu_sort_by_size"
                            app:iconGravity="textStart"
                            android:textAllCaps="false"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/viewGridButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Сетка"
                            android:textSize="14sp"
                            app:icon="@android:drawable/ic_menu_view"
                            app:iconGravity="textStart"
                            android:textAllCaps="false"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Кнопки управления в стиле Т-Банка -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingHorizontal="16dp"
                android:layout_marginBottom="16dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/loadButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="Загрузить"
                    android:textSize="16sp"
                    android:textColor="@color/tbank_black"
                    android:backgroundTint="@color/tbank_yellow"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/stat_notify_sync"
                    app:iconTint="@color/tbank_black"
                    app:iconGravity="textStart"
                    android:textAllCaps="false"
                    style="@style/Widget.Material3.Button.ElevatedButton" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/settingsButton"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="Настройки"
                    android:textSize="16sp"
                    android:textColor="@color/tbank_black"
                    app:strokeColor="@color/tbank_yellow"
                    app:strokeWidth="2dp"
                    app:cornerRadius="12dp"
                    app:icon="@android:drawable/ic_menu_preferences"
                    app:iconTint="@color/tbank_black"
                    app:iconGravity="textStart"
                    android:textAllCaps="false" />

            </LinearLayout>

            <!-- НОВАЯ ПАНЕЛЬ: Пагинация и экспорт -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="12dp"
                app:cardCornerRadius="12dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginBottom="12dp">

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="📄 Управление данными"
                            android:textAppearance="?attr/textAppearanceTitleMedium"
                            android:textColor="@color/tbank_black"
                            android:textStyle="bold" />

                        <TextView
                            android:id="@+id/pageInfoText"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Стр. 1"
                            android:textAppearance="?attr/textAppearanceBodyMedium"
                            android:textColor="@color/tbank_yellow"
                            android:textStyle="bold"
                            android:paddingHorizontal="12dp"
                            android:paddingVertical="4dp"
                            android:background="@android:drawable/dialog_holo_light_frame" />

                    </LinearLayout>

                    <!-- Пагинация -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:layout_marginBottom="8dp">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/prevPageButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="◀ Назад"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/tbank_yellow" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/nextPageButton"
                            style="@style/Widget.Material3.Button.OutlinedButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Вперед ▶"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            app:cornerRadius="8dp"
                            app:strokeColor="@color/tbank_yellow" />

                    </LinearLayout>

                    <!-- Экспорт данных -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/exportJsonButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="4dp"
                            android:text="JSON"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_menu_save"
                            app:iconGravity="start"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/exportCsvButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:layout_marginEnd="4dp"
                            android:text="CSV"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_menu_save"
                            app:iconGravity="start"
                            app:cornerRadius="8dp" />

                        <com.google.android.material.button.MaterialButton
                            android:id="@+id/shareButton"
                            style="@style/Widget.Material3.Button.TonalButton"
                            android:layout_width="0dp"
                            android:layout_height="48dp"
                            android:layout_weight="1"
                            android:layout_marginStart="4dp"
                            android:text="Отправить"
                            android:textSize="14sp"
                            android:textAllCaps="false"
                            app:icon="@android:drawable/ic_menu_share"
                            app:iconGravity="start"
                            app:cornerRadius="8dp" />

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- ProgressBar в стиле Т-Банка -->
            <com.google.android.material.progressindicator.LinearProgressIndicator
                android:id="@+id/progressBar"
                android:layout_width="match_parent"
                android:layout_height="4dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/tbank_yellow"
                app:trackColor="@color/md_theme_light_surfaceVariant"
                app:trackCornerRadius="2dp"
                tools:visibility="visible" />

            <!-- Пустое состояние -->
            <LinearLayout
                android:id="@+id/emptyView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="48dp"
                android:layout_marginHorizontal="32dp"
                android:gravity="center"
                android:orientation="vertical"
                android:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="💳"
                    android:textSize="72sp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="24dp"
                    android:text="Список пуст"
                    android:textAlignment="center"
                    android:textAppearance="?attr/textAppearanceHeadlineSmall"
                    android:textColor="?attr/colorOnBackground"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:text="Нажмите «Загрузить» для получения данных"
                    android:textAlignment="center"
                    android:textAppearance="?attr/textAppearanceBodyLarge"
                    android:textColor="?attr/colorOnSurfaceVariant" />

            </LinearLayout>

            <!-- RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recyclerView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipToPadding="false"
                android:visibility="gone"
                tools:itemCount="15"
                tools:listitem="@layout/item_user"
                tools:visibility="visible" />

            <!-- Профессиональный экран загрузки -->
            <FrameLayout
                android:id="@+id/loadingOverlay"
                android:layout_width="match_parent"
                android:layout_height="400dp"
                android:background="@android:color/white"
                android:visibility="gone"
                android:elevation="8dp"
                android:layout_marginHorizontal="16dp"
                android:layout_marginBottom="16dp"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="32dp">

                    <!-- Пульсирующая иконка -->
                    <TextView
                        android:id="@+id/loadingIcon"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💳"
                        android:textSize="80sp"
                        android:alpha="1.0" />

                    <!-- Прогресс-бар -->
                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/circularProgress"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:indeterminate="true"
                        app:indicatorSize="48dp"
                        app:indicatorColor="@color/tbank_yellow"
                        app:trackColor="@color/md_theme_light_surfaceVariant"
                        app:trackThickness="4dp" />

                    <!-- Заголовок -->
                    <TextView
                        android:id="@+id/loadingTitle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="24dp"
                        android:text="Загрузка данных..."
                        android:textAppearance="?attr/textAppearanceHeadlineSmall"
                        android:textColor="?attr/colorOnBackground"
                        android:textStyle="bold" />

                    <!-- Статус -->
                    <TextView
                        android:id="@+id/loadingStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Поиск по сети..."
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                    <!-- Разделитель -->
                    <View
                        android:layout_width="60dp"
                        android:layout_height="3dp"
                        android:layout_marginTop="24dp"
                        android:background="@color/tbank_yellow"
                        android:alpha="0.8" />

                    <!-- Авторство -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="16dp"
                        android:text="Лабораторная работа №8"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="4dp"
                        android:text="Пекун Марк Сергеевич"
                        android:textAppearance="?attr/textAppearanceBodyMedium"
                        android:textColor="@color/tbank_yellow"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2dp"
                        android:text="Группа АС-66"
                        android:textAppearance="?attr/textAppearanceBodySmall"
                        android:textColor="?attr/colorOnSurfaceVariant" />

                </LinearLayout>

            </FrameLayout>

            <!-- Footer с авторством в стиле Т-Банка -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:layout_marginTop="32dp"
                android:layout_marginBottom="16dp"
                android:orientation="horizontal"
                android:gravity="center">
                
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/tbank_yellow"
                    android:layout_marginEnd="12dp" />
                
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="Лабораторная работа №8\nПекун Марк Сергеевич • АС-66"
                    android:textAppearance="?attr/textAppearanceBodySmall"
                    android:textColor="?attr/colorOnSurfaceVariant"
                    android:textStyle="bold" />
                
                <View
                    android:layout_width="40dp"
                    android:layout_height="2dp"
                    android:background="@color/tbank_yellow"
                    android:layout_marginStart="12dp" />
                
            </LinearLayout>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>

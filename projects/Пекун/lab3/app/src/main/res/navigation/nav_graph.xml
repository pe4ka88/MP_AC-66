<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/splashFragment">

    <!-- Splash экран с авторством -->
    <fragment
        android:id="@+id/splashFragment"
        android:name="com.example.thirdlab8.ui.SplashFragment"
        android:label="Лабораторная №8"
        tools:layout="@layout/fragment_splash">
        
        <action
            android:id="@+id/action_splash_to_userList"
            app:destination="@id/userListFragment"
            app:popUpTo="@id/splashFragment"
            app:popUpToInclusive="true" />
    </fragment>

    <!-- Список пользователей -->
    <fragment
        android:id="@+id/userListFragment"
        android:name="com.example.thirdlab8.ui.list.UserListFragment"
        android:label="Список пользователей"
        tools:layout="@layout/fragment_user_list">
        
        <action
            android:id="@+id/action_userList_to_userDetail"
            app:destination="@id/userDetailFragment"
            app:enterAnim="@android:anim/slide_in_left"
            app:exitAnim="@android:anim/slide_out_right"
            app:popEnterAnim="@android:anim/slide_in_left"
            app:popExitAnim="@android:anim/slide_out_right" />
        
        <action
            android:id="@+id/action_userList_to_settings"
            app:destination="@id/settingsFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out"
            app:popEnterAnim="@android:anim/fade_in"
            app:popExitAnim="@android:anim/fade_out" />
        
        <action
            android:id="@+id/action_userList_to_about"
            app:destination="@id/aboutFragment"
            app:enterAnim="@android:anim/fade_in"
            app:exitAnim="@android:anim/fade_out" />
    </fragment>

    <!-- Детали пользователя -->
    <fragment
        android:id="@+id/userDetailFragment"
        android:name="com.example.thirdlab8.ui.detail.UserDetailFragment"
        android:label="Детали"
        tools:layout="@layout/fragment_user_detail" />

    <!-- Настройки -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.example.thirdlab8.ui.settings.SettingsFragment"
        android:label="Настройки"
        tools:layout="@layout/fragment_settings" />

    <!-- О приложении -->
    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.example.thirdlab8.ui.AboutFragment"
        android:label="О приложении"
        tools:layout="@layout/fragment_about" />

</navigation>

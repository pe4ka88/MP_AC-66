<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.Lab1MemoryGame" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:textColorPrimary">@color/text_primary</item>
        <item name="android:textColorSecondary">@color/text_secondary</item>
        
        <!-- ✅ ФИКС: Явно указываем светлую тему для диалогов -->
        <item name="alertDialogTheme">@style/Theme.Lab1MemoryGame.Dialog</item>
        <item name="materialAlertDialogTheme">@style/Theme.Lab1MemoryGame.Dialog</item>
    </style>

    <style name="Theme.Lab1MemoryGame" parent="Base.Theme.Lab1MemoryGame" />
    
    <style name="Theme.Lab1MemoryGame.NoActionBar" parent="Theme.Lab1MemoryGame">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>
    
    <!-- ✅ Светлая тема для диалогов -->
    <style name="Theme.Lab1MemoryGame.Dialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorSecondary">@color/secondary</item>
        <item name="colorSurface">@color/surface</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="android:background">@color/surface</item>
        <item name="backgroundTint">@color/surface</item>
        <item name="materialAlertDialogTitleTextStyle">@style/MaterialAlertDialog.Title</item>
        <item name="materialAlertDialogBodyTextStyle">@style/MaterialAlertDialog.Body</item>
        <item name="buttonBarPositiveButtonStyle">@style/MaterialAlertDialog.Button</item>
        <item name="buttonBarNegativeButtonStyle">@style/MaterialAlertDialog.Button</item>
        <item name="buttonBarNeutralButtonStyle">@style/MaterialAlertDialog.Button</item>
    </style>
    
    <style name="MaterialAlertDialog.Title" parent="MaterialAlertDialog.MaterialComponents.Title.Text">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textSize">20sp</item>
        <item name="android:textStyle">bold</item>
    </style>
    
    <style name="MaterialAlertDialog.Body" parent="MaterialAlertDialog.MaterialComponents.Body.Text">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textSize">16sp</item>
    </style>
    
    <style name="MaterialAlertDialog.Button" parent="Widget.Material3.Button.TextButton.Dialog">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textStyle">bold</item>
    </style>
</resources>
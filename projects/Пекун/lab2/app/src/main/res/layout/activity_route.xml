<?xml version="1.0" encoding="utf-8"?>
<!-- 
    Макет экрана выбора маршрута (RouteActivity)
    
    Содержит:
    - 6 полей для ввода параметров маршрута
    - Кнопку подтверждения выбора
    - Обязательные поля: "Откуда" и "Куда"
    - Необязательные поля: улица, дом, комментарий, доп. информация
    
    Автор: Пекун Марк Сергеевич
    Группа: АС-66
    Лабораторная работа №7
-->
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F5F5F5">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="24dp">

        <!-- Заголовок экрана с иконкой карты -->
        <TextView
            android:id="@+id/tvHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🗺️ Настройка маршрута"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#FF6B00"
            android:layout_marginTop="24dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Информация об авторе -->
        <TextView
            android:id="@+id/tvAuthorRoute"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Разработал Пекун Марк Сергеевич, группа АС-66"
            android:textSize="12sp"
            android:textColor="#616161"
            android:textStyle="italic"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@id/tvHeader"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Карточка со всеми полями маршрута -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/cardRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="4dp"
            app:layout_constraintTop_toBottomOf="@id/tvAuthorRoute">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Поле 1: Откуда (обязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilFrom"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="📍 Откуда"
                    app:startIconDrawable="@android:drawable/ic_menu_mylocation"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etFrom"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Поле 2: Куда (обязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilTo"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="🎯 Куда"
                    app:startIconDrawable="@android:drawable/ic_menu_compass"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etTo"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Поле 3: Улица (необязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilStreet"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="🏙️ Улица"
                    app:startIconDrawable="@android:drawable/ic_menu_directions"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etStreet"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPostalAddress"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Поле 4: Дом (необязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilHouse"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="🏠 Дом"
                    app:startIconDrawable="@android:drawable/ic_menu_info_details"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etHouse"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="1" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Поле 5: Комментарий (необязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilComment"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="💬 Комментарий"
                    app:startIconDrawable="@android:drawable/ic_menu_edit"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etComment"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textMultiLine"
                        android:maxLines="3" />
                </com.google.android.material.textfield.TextInputLayout>

                <!-- Поле 6: Дополнительная информация (необязательное) -->
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/tilAdditional"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="➕ Дополнительная информация"
                    app:startIconDrawable="@android:drawable/ic_menu_add"
                    app:boxBackgroundMode="outline"
                    app:boxCornerRadiusTopStart="8dp"
                    app:boxCornerRadiusTopEnd="8dp"
                    app:boxCornerRadiusBottomStart="8dp"
                    app:boxCornerRadiusBottomEnd="8dp">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/etAdditional"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="text"
                        android:maxLines="2" />
                </com.google.android.material.textfield.TextInputLayout>

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <!-- Кнопка подтверждения маршрута -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnOk"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_marginTop="24dp"
            android:text="✓ Подтвердить маршрут"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="12dp"
            app:icon="@android:drawable/ic_menu_save"
            app:iconGravity="textStart"
            app:backgroundTint="#4CAF50"
            app:layout_constraintTop_toBottomOf="@id/cardRoute" />

        <!-- Подсказка об обязательных полях -->
        <TextView
            android:id="@+id/tvInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="* Поля 'Откуда' и 'Куда' обязательны для заполнения"
            android:textSize="12sp"
            android:textColor="#9E9E9E"
            android:layout_marginTop="16dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/btnOk"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- Номер лабораторной работы -->
        <TextView
            android:id="@+id/tvLabWork"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Лабораторная работа №7"
            android:textSize="14sp"
            android:textColor="#FF6B00"
            android:textStyle="bold"
            android:layout_marginTop="12dp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/tvInfo"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>

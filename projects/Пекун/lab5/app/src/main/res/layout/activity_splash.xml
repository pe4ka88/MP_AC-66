<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_screen_gradient"
    android:gravity="center"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:id="@+id/logoMark"
        android:layout_width="82dp"
        android:layout_height="82dp"
        android:background="@drawable/bg_primary_button" />

    <TextView
        android:id="@+id/textSplashTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="18dp"
        android:text="@string/splash_title"
        android:textColor="#16324A"
        android:textSize="30sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textSplashSubtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/splash_subtitle"
        android:textColor="#4D6A82"
        android:textSize="14sp" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/splashProgress"
        android:layout_width="180dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp" />

</LinearLayout>

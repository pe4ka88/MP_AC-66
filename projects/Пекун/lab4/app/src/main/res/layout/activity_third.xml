<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header — fixed alignment, proper gravity -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="8dp"
        android:paddingEnd="20dp"
        android:paddingTop="18dp"
        android:paddingBottom="22dp"
        android:elevation="6dp">

        <ImageButton
            android:id="@+id/btnBackThird"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:src="@drawable/ic_arrow_back"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Назад"
            android:scaleType="center"/>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="6dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="О задании"
                android:textSize="22sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Лабораторная работа №9"
                android:textSize="12sp"
                android:textColor="#A8E6D4"
                android:layout_marginTop="3dp"/>

        </LinearLayout>

    </LinearLayout>

    <!-- Scrollable content — fixed padding and clipping -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:overScrollMode="ifContentScrolls">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="20dp"
            android:paddingBottom="24dp">

            <!-- ① Task title card — increased contrast, clear bold heading -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Лабораторная работа №9"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/emerald"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Списки. Создание собственного адаптера.\nМеханизмы обратного вызова."
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="6dp"
                    android:lineSpacingMultiplier="1.5"/>

            </LinearLayout>

            <!-- ② Task checklist card — consistent padding, proper heading margin -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_white_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="10dp"
                android:elevation="4dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Практические задания:"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginBottom="8dp"/>

                <include layout="@layout/item_task_row" android:id="@+id/task1"/>
                <include layout="@layout/item_task_row" android:id="@+id/task2"/>
                <include layout="@layout/item_task_row" android:id="@+id/task3"/>
                <include layout="@layout/item_task_row" android:id="@+id/task4"/>
                <include layout="@layout/item_task_row" android:id="@+id/task5"/>
                <include layout="@layout/item_task_row" android:id="@+id/task6"/>

            </LinearLayout>

            <!-- ③ Author signature card — proper spacing, correct university -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/bg_info_card"
                android:paddingStart="18dp"
                android:paddingEnd="18dp"
                android:paddingTop="18dp"
                android:paddingBottom="18dp"
                android:elevation="4dp"
                android:layout_marginBottom="20dp">

                <!-- Avatar + name row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="14dp">

                    <FrameLayout
                        android:layout_width="52dp"
                        android:layout_height="52dp"
                        android:background="@drawable/bg_avatar">
                        <ImageView
                            android:layout_width="30dp"
                            android:layout_height="30dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_person"/>
                    </FrameLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:layout_marginStart="14dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Выполнил:"
                            android:textSize="11sp"
                            android:textColor="@color/text_muted"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Пекун Марк Сергеевич"
                            android:textSize="15sp"
                            android:textStyle="bold"
                            android:textColor="@color/text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Группа АС-66  •  2026"
                            android:textSize="12sp"
                            android:textColor="@color/text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#D4EFE6"
                    android:layout_marginBottom="14dp"/>

                <!-- University row — FIXED name -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="top">

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:src="@drawable/ic_university"
                        android:layout_marginEnd="12dp"
                        android:layout_marginTop="1dp"/>

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Брестский государственный технический университет"
                        android:textSize="12sp"
                        android:textColor="@color/text_secondary"
                        android:lineSpacingMultiplier="1.4"/>

                </LinearLayout>

            </LinearLayout>

            <!-- ④ Proof button -->
            <Button
                android:id="@+id/btnAuthorProof"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Работу выполнил Пекун М.С."
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_button_primary_pressed"
                android:stateListAnimator="@null"
                android:layout_marginBottom="16dp"/>

            <!-- ⑤ Footer copyright — FIXED text -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="© 2026 Пекун Марк Сергеевич, группа АС-66\nБрестский государственный технический университет"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:gravity="center"
                android:lineSpacingMultiplier="1.5"
                android:layout_marginBottom="8dp"/>

        </LinearLayout>

    </ScrollView>

</LinearLayout>

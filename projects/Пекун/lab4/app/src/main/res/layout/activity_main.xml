<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_screen">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_header"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="20dp"
        android:paddingBottom="24dp"
        android:elevation="6dp">

        <!-- Row: icon + title -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <FrameLayout
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:background="@drawable/bg_white_card"
                android:elevation="2dp">
                <ImageView
                    android:layout_width="26dp"
                    android:layout_height="26dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_cart"
                    android:alpha="0.85"/>
            </FrameLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="MiniShop"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:textColor="#FFFFFF"
                    android:fontFamily="sans-serif-medium"
                    android:letterSpacing="0.01"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Лабораторная работа №9"
                    android:textSize="12sp"
                    android:textColor="#CCF0E5"
                    android:layout_marginTop="1dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Author line -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Разработал: Пекун Марк Сергеевич, группа АС-66"
            android:textSize="11sp"
            android:textColor="#A8E6D4"
            android:layout_marginTop="8dp"
            android:layout_marginStart="54dp"/>

    </LinearLayout>

    <!-- Loading state -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- ListView -->
        <ListView
            android:id="@+id/listViewProducts"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:divider="@null"
            android:dividerHeight="0dp"
            android:paddingTop="10dp"
            android:paddingBottom="4dp"
            android:clipToPadding="false"
            android:scrollbarStyle="outsideOverlay"/>

        <!-- Loading overlay -->
        <LinearLayout
            android:id="@+id/loadingContainer"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center"
            android:visibility="gone">

            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:indeterminateTint="@color/emerald"/>

            <TextView
                android:id="@+id/tvLoadingHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Загружаем товары из FakeStore…"
                android:textSize="13sp"
                android:textColor="@color/text_secondary"
                android:layout_marginTop="14dp"/>

        </LinearLayout>

    </FrameLayout>

    <!-- Sticky Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@drawable/bg_footer_container"
        android:paddingTop="16dp"
        android:paddingBottom="16dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:elevation="16dp">

        <!-- Counter row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Выбрано товаров"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                android:fontFamily="sans-serif"/>

            <TextView
                android:id="@+id/tvCheckedCount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:background="@drawable/bg_badge"
                android:minWidth="30dp"
                android:gravity="center"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:paddingTop="4dp"
                android:paddingBottom="4dp"/>

        </LinearLayout>

        <!-- Primary Button -->
        <Button
            android:id="@+id/btnShowChecked"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="В корзину →"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_button_primary_pressed"
            android:letterSpacing="0.03"
            android:stateListAnimator="@null"
            android:layout_marginBottom="8dp"/>

        <!-- Row: secondary button + copyright -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal">

            <Button
                android:id="@+id/btnAbout"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:text="О задании"
                android:textSize="13sp"
                android:textColor="#FFFFFF"
                android:fontFamily="sans-serif-medium"
                android:background="@drawable/bg_button_primary_pressed"
                android:stateListAnimator="@null"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="© Пекун М.С., АС-66"
                android:textSize="11sp"
                android:textColor="@color/text_muted"
                android:fontFamily="sans-serif"/>

        </LinearLayout>

    </LinearLayout>

</LinearLayout>
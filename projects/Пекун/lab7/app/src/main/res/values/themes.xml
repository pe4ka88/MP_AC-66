<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Base.Theme.LabSeven17" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="colorPrimary">@color/brand_teal</item>
        <item name="colorSecondary">@color/brand_blue</item>
        <item name="colorSurface">@color/surface_panel</item>
        <item name="android:windowBackground">@drawable/bg_app_gradient</item>
    </style>

    <style name="Theme.LabSeven17" parent="Base.Theme.LabSeven17" />

    <style name="Widget.LabSeven17.MenuCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">22dp</item>
        <item name="cardBackgroundColor">@color/surface_glass</item>
        <item name="strokeColor">#40FFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
        <item name="android:foreground">?attr/selectableItemBackground</item>
    </style>

    <style name="Widget.LabSeven17.MenuCardText" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="android:padding">18dp</item>
        <item name="android:textColor">@color/text_on_dark</item>
        <item name="android:textSize">17sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.LabSeven17.PanelCard" parent="Widget.Material3.CardView.Elevated">
        <item name="android:layout_width">match_parent</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardBackgroundColor">@color/surface_glass</item>
        <item name="strokeColor">#45FFFFFF</item>
        <item name="strokeWidth">1dp</item>
        <item name="cardElevation">0dp</item>
    </style>

    <style name="Widget.LabSeven17.PrimaryButton" parent="Widget.Material3.Button">
        <item name="cornerRadius">16dp</item>
        <item name="backgroundTint">@color/brand_teal</item>
        <item name="android:textColor">#102037</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="Widget.LabSeven17.ControlButton" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:layout_width">wrap_content</item>
        <item name="android:layout_height">wrap_content</item>
        <item name="shapeAppearanceOverlay">@style/ShapeAppearance.Material3.Corner.Large</item>
        <item name="strokeColor">@color/brand_teal</item>
        <item name="android:textColor">@color/text_on_dark</item>
    </style>
</resources>
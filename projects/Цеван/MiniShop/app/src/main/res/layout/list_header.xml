<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="#CFE8FF">

    <TextView
        android:id="@+id/tvHeaderTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="MiniShop - Список товаров"
        android:textSize="24sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="6dp" />

    <TextView
        android:id="@+id/tvHeaderAuthor1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Выполнил Цеван Константин, АС-66"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tvHeaderAuthor2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Разработал Цеван Константин"
        android:textSize="16sp"
        android:gravity="center"
        android:paddingBottom="4dp" />

    <TextView
        android:id="@+id/tvTaskInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ЛР: Списки. Создание собственного адаптера. Механизмы обратного вызова."
        android:textSize="14sp"
        android:gravity="center" />

</LinearLayout>
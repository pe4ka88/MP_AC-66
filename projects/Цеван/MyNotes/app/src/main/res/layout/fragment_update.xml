<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:orientation="vertical" android:padding="16dp">
    <EditText android:id="@+id/etIdUpdate" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="ID заметки" android:inputType="number"/>
    <EditText android:id="@+id/etDescUpdate" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Новый текст" />
    <Button android:id="@+id/btnUpdate" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Update (Нажимает Цеван)" />
</LinearLayout>

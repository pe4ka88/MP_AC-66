<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <!-- Инициалы в правом верхнем углу -->
    <TextView
        android:id="@+id/initialsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="К.Н."
        android:textSize="16sp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"/>

    <!-- Заголовок -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="MEMORY GAME"
        style="@style/MainText"
        android:layout_marginTop="40dp"
        android:layout_marginBottom="60dp"/>

    <!-- Кнопки меню -->
    <Button
        android:id="@+id/startButton"
        android:text="НАЧАТЬ ИГРУ"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/recordsButton"
        android:text="РЕКОРДЫ"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/settingsButton"
        android:text="НАСТРОЙКИ"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/cookieButton"
        android:text="ПРАВИЛА COOKIE"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/taskButton"
        android:text="ЗАДАНИЕ ЛР1"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/authorButton"
        android:text="НАЖИМАЕТ КУГАН"
        style="@style/MenuButton"/>

    <Button
        android:id="@+id/exitButton"
        android:text="ВЫХОД"
        style="@style/MenuButton"
        android:layout_marginBottom="40dp"/>

    <!-- Разработчик внизу -->
    <TextView
        android:id="@+id/developerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Разработчик: Куган Н. Л.\nГруппа: АС-66\n2026 год"
        style="@style/SmallText"
        android:layout_marginTop="20dp"/>

</LinearLayout>
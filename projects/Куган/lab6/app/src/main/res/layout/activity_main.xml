<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- ========== ПРИЗНАКИ АВТОРСТВА ========== -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="#3F51B5"
            android:padding="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="📁 File Explorer"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"
                android:gravity="center"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Куган Н. Л., гр. АС-66"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:gravity="center"
                android:layout_marginTop="4dp"/>
        </LinearLayout>

        <!-- ========== ПОГОДА В БРЕСТЕ (API) ========== -->
        <androidx.cardview.widget.CardView
            android:id="@+id/weatherCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:background="@drawable/weather_gradient">

                <TextView
                    android:id="@+id/tvWeatherIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳"
                    android:textSize="40sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Погода в Бресте"
                        android:textSize="14sp"
                        android:textColor="#666666"/>

                    <TextView
                        android:id="@+id/tvWeatherTemp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textSize="24sp"
                        android:textStyle="bold"/>

                    <TextView
                        android:id="@+id/tvWeatherDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Загрузка..."
                        android:textSize="14sp"
                        android:textColor="#666666"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ========== КНОПКА ВЫБОРА ФАЙЛА ========== -->
        <Button
            android:id="@+id/btnChooseFile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📂 Выбрать файл (Нажимает Куган)"
            android:backgroundTint="#4CAF50"
            android:textSize="16sp"
            android:padding="12dp"
            android:layout_marginBottom="16dp"/>

        <!-- ========== ИНФОРМАЦИЯ О ВЫБРАННОМ ФАЙЛЕ ========== -->
        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Файл не выбран"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="#E0E0E0"
            android:layout_marginBottom="16dp"/>

        <!-- ========== ОБЛАСТЬ ДЛЯ ИЗОБРАЖЕНИЯ ========== -->
        <TextView
            android:id="@+id/tvImageLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🖼️ Изображение:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <ImageView
            android:id="@+id/imageView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <!-- ========== ОБЛАСТЬ ДЛЯ АУДИО ========== -->
        <TextView
            android:id="@+id/tvAudioLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎵 Аудио:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <LinearLayout
            android:id="@+id/audioControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnPlayAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶️ Play"
                android:backgroundTint="#2196F3"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnPauseAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏸️ Pause"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="4dp"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnStopAudio"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏹️ Stop"
                android:backgroundTint="#F44336"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- ========== ОБЛАСТЬ ДЛЯ ВИДЕО ========== -->
        <TextView
            android:id="@+id/tvVideoLabel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🎬 Видео:"
            android:textSize="16sp"
            android:textStyle="bold"
            android:visibility="gone"/>

        <VideoView
            android:id="@+id/videoView"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:visibility="gone"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="16dp"/>

        <LinearLayout
            android:id="@+id/videoControls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:visibility="gone"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btnPlayVideo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="▶️ Play"
                android:backgroundTint="#2196F3"
                android:layout_marginEnd="4dp"/>

            <Button
                android:id="@+id/btnPauseVideo"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="⏸️ Pause"
                android:backgroundTint="#FF9800"
                android:layout_marginStart="4dp"/>
        </LinearLayout>

        <!-- ========== ПРИЗНАК АВТОРСТВА ВНИЗУ ========== -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Разработала: Куган Н. Л."
            android:textSize="12sp"
            android:gravity="center"
            android:padding="8dp"
            android:background="#E0E0E0"
            android:layout_marginTop="16dp"/>

    </LinearLayout>
</ScrollView>
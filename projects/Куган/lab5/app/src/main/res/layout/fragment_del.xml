<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ Удаление заметки (Куган Н. Л.)"
        android:textSize="18sp"
        android:textStyle="bold"
        android:padding="12dp"
        android:background="#E0E0E0"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Номер заметки для удаления:"
        android:textSize="16sp"
        android:layout_marginTop="24dp"/>

    <EditText
        android:id="@+id/etNoteId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Введите ID заметки"
        android:inputType="number"
        android:padding="12dp"
        android:background="@android:drawable/editbox_background"
        android:layout_marginTop="8dp"/>

    <Button
        android:id="@+id/btnDeleteNote"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🗑️ Delete Note (Нажимает Куган)"
        android:backgroundTint="#F44336"
        android:layout_marginTop="24dp"/>

    <TextView
        android:id="@+id/tvDeleteResult"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="14sp"
        android:gravity="center"
        android:layout_marginTop="16dp"/>

</LinearLayout>
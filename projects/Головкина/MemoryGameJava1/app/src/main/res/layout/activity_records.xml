<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <!-- Инициалы -->
    <TextView
        android:id="@+id/initialsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="В.Г."
        android:textSize="16sp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"/>

    <!-- Заголовок -->
    <TextView
        android:id="@+id/recordsTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ТАБЛИЦА РЕКОРДОВ"
        style="@style/MainText"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <!-- Рекорды 2x2 -->
    <TextView
        android:id="@+id/records2x2"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Поле 2x2:\nНет рекордов"
        style="@style/SecondaryText"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:padding="12dp"/>

    <!-- Рекорды 3x3 -->
    <TextView
        android:id="@+id/records3x3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Поле 3x3:\nНет рекордов"
        style="@style/SecondaryText"
        android:gravity="center"
        android:layout_marginBottom="20dp"
        android:padding="12dp"/>

    <!-- Рекорды 4x4 -->
    <TextView
        android:id="@+id/records4x4"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Поле 4x4:\nНет рекордов"
        style="@style/SecondaryText"
        android:gravity="center"
        android:layout_marginBottom="40dp"
        android:padding="12dp"/>

    <!-- Кнопка назад -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="НАЗАД"
        android:textSize="18sp"
        android:layout_marginBottom="40dp"/>

    <!-- Разработчик внизу - ДОБАВЬТЕ ЭТОТ TextView С ID -->
    <TextView
        android:id="@+id/developerInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Разработчик приложения:\nГоловкина Виктория\nГруппа АС-66\n2026 год"
        style="@style/SmallText"/>

</LinearLayout>
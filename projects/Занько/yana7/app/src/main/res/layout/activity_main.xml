<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Лабораторная работа №7 (17)\nРазработал: Занько Я.С.., АС-66"
        android:textAlignment="center"
        android:textStyle="bold"
        android:textColor="#3F51B5"
        android:layout_marginBottom="10dp" />

    <Button
        android:id="@+id/btnPickAudio"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#6750A4"
        android:text="1. Выбрать Аудио (Занько Я.С..)" />
    
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/btnPlayAudio" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Пуск" />
        <Button android:id="@+id/btnPauseAudio" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Пауза" />
    </LinearLayout>

    <Button
        android:id="@+id/btnPickVideo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#6750A4"
        android:layout_marginTop="5dp"
        android:text="2. Выбрать Видео (АС-66)" />

    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:layout_gravity="center" />

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content">
        <Button android:id="@+id/btnPlayVideo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Пуск Видео" />
        <Button android:id="@+id/btnPauseVideo" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:text="Пауза Видео" />
    </LinearLayout>

    <ImageView
        android:id="@+id/imageView"
        android:layout_width="match_parent"
        android:layout_height="120dp"
        android:layout_marginTop="5dp"
        android:src="@android:drawable/ic_menu_camera" />

    <Button
        android:id="@+id/btnMakePhoto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:backgroundTint="#6750A4"
        android:text="3. Сделать фото (Занько Я.С..)" />
</LinearLayout>

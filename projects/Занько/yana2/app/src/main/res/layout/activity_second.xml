<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Taxi — User &amp; Route"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Авторство -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingTop="8dp"
            android:text="Разработал: Занько Я.С., группа АС-66" />

        <TextView
            android:id="@+id/tvName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Имя и фамилия: "
            android:textSize="16sp"
            android:paddingTop="12dp" />

        <TextView
            android:id="@+id/tvPhone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Телефон: "
            android:textSize="16sp" />

        <TextView
            android:id="@+id/tvRoute"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Маршрут: (пусто)"
            android:paddingTop="12dp"
            android:textSize="16sp" />

        <Button
            android:id="@+id/btnSetPath"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Set path" />

        <Button
            android:id="@+id/btnCallTaxi"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Call Taxi"
            android:enabled="false" />

        <Button
            android:id="@+id/btnBack"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Назад" />

    </LinearLayout>
</ScrollView>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="center">

    <!-- Инициалы -->
    <TextView
        android:id="@+id/initialsText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="М.С."
        android:textSize="16sp"
        android:layout_gravity="end"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="10dp"/>

    <!-- Заголовок -->
    <TextView
        android:id="@+id/titleTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ВЫБЕРИТЕ РАЗМЕР ПОЛЯ"
        style="@style/MainText"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="40dp"/>

    <!-- Выбор размера -->
    <RadioGroup
        android:id="@+id/sizeRadioGroup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="40dp">

        <RadioButton
            android:id="@+id/radio2x2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="2x2 (4 карточки, 2 пары)"
            style="@style/SecondaryText"
            android:layout_marginBottom="20dp"/>

        <RadioButton
            android:id="@+id/radio3x3"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3x3 (9 карточек, 3 набора)"
            style="@style/SecondaryText"
            android:layout_marginBottom="20dp"/>

        <RadioButton
            android:id="@+id/radio4x4"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="4x4 (16 карточек, 8 пар)"
            style="@style/SecondaryText"/>

    </RadioGroup>

    <!-- Кнопка начала игры -->
    <Button
        android:id="@+id/startButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="НАЧАТЬ ИГРУ"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"/>

    <!-- Кнопка назад -->
    <Button
        android:id="@+id/backButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="НАЗАД"
        android:textSize="18sp"
        android:layout_marginBottom="40dp"/>

    <!-- Разработчик внизу -->
    <TextView
        android:id="@+id/developerText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Разработчик: Савинец М. Д.\nГруппа: АС-66\n2026 год"
        style="@style/SmallText"/>

</LinearLayout>
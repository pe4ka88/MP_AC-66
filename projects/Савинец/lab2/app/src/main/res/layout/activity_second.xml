<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Экран заказа такси"
        android:textSize="18sp"
        android:textStyle="bold"
        android:layout_gravity="center_horizontal"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Савинец М. Д., гр. АС-66"
        android:textSize="14sp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"/>

    <!-- TextView для вывода имени и фамилии -->
    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Пассажир: "
        android:textSize="16sp"
        android:layout_marginTop="16dp"/>

    <!-- TextView для вывода телефона -->
    <TextView
        android:id="@+id/tvUserPhone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Телефон: "
        android:textSize="16sp"
        android:layout_marginTop="8dp"/>

    <!-- 🔥 НОВЫЙ БЛОК ПОГОДЫ ДЛЯ БРЕСТА 🔥 -->
    <androidx.cardview.widget.CardView
        android:id="@+id/weatherCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        xmlns:app="http://schemas.android.com/apk/res-auto">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@drawable/weather_gradient">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🌤 Погода в Бресте сейчас"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="12dp">

                <TextView
                    android:id="@+id/tvWeatherIcon"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="⏳"
                    android:textSize="48sp"
                    android:layout_marginEnd="16dp"/>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:id="@+id/tvTemperature"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="--°C"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvWeatherDesc"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Загрузка..."
                        android:textSize="16sp"
                        android:textColor="#FFFFFF"/>

                    <TextView
                        android:id="@+id/tvWindHumidity"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="💨 -- м/с, 💧 --%"
                        android:textSize="14sp"
                        android:textColor="#FFFFFF"
                        android:layout_marginTop="4dp"/>
                </LinearLayout>
            </LinearLayout>

            <TextView
                android:id="@+id/tvUpdateTime"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Обновление..."
                android:textSize="12sp"
                android:textColor="#AAFFFFFF"
                android:layout_marginTop="8dp"/>
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- TextView для вывода маршрута -->
    <TextView
        android:id="@+id/tvRoute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Маршрут: не задан"
        android:textSize="16sp"
        android:layout_marginTop="16dp"
        android:padding="8dp"
        android:background="@android:drawable/editbox_background"/>

    <!-- Кнопка Set path -->
    <Button
        android:id="@+id/btnSetPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Set path (Нажимает Савинец)"
        android:layout_marginTop="16dp"/>

    <!-- Кнопка Call Taxi -->
    <Button
        android:id="@+id/btnCallTaxi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Call Taxi"
        android:enabled="false"
        android:layout_marginTop="8dp"/>

    <!-- Признак авторства -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Разработала: Савинец М. Д."
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="24dp"
        android:textSize="12sp"/>

</LinearLayout>
<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Theme.MemoryGame" parent="Theme.AppCompat.DayNight.NoActionBar">
        <!-- Основные цвета для темной темы -->
        <item name="colorPrimary">#BB86FC</item>
        <item name="colorPrimaryVariant">#3700B3</item>
        <item name="colorOnPrimary">#000000</item>

        <!-- Вторичные цвета -->
        <item name="colorSecondary">#03DAC6</item>
        <item name="colorSecondaryVariant">#018786</item>
        <item name="colorOnSecondary">#000000</item>

        <!-- Фон и поверхность -->
        <item name="android:colorBackground">#121212</item>
        <item name="colorSurface">#121212</item>
        <item name="colorOnSurface">#FFFFFF</item>

        <!-- Статус бар -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>

        <!-- Ошибка -->
        <item name="colorError">#CF6679</item>
        <item name="colorOnError">#000000</item>
    </style>
</resources>
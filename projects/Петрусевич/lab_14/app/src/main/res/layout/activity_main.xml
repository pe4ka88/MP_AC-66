<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_deep"
    tools:context=".MainActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="МЕДИА ЦЕНТР"
            android:textColor="@color/accent_neon_pink"
            android:textSize="32sp"
            android:textStyle="bold"
            android:layout_marginBottom="16dp"
            android:fontFamily="sans-serif-condensed"/>

        <TextView
            android:id="@+id/text_location"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Координаты: определение..."
            android:textColor="@color/accent_neon_cyan"
            android:textSize="12sp"
            android:layout_marginBottom="24dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_audio"
            android:layout_width="240dp"
            android:layout_height="55dp"
            android:text="Аудио"
            android:textColor="@color/white"
            android:background="@drawable/button_background"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_video"
            android:layout_width="240dp"
            android:layout_height="55dp"
            android:text="Видео"
            android:textColor="@color/white"
            android:background="@drawable/button_background"
            android:layout_marginBottom="12dp"/>

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/button_photo"
            android:layout_width="240dp"
            android:layout_height="55dp"
            android:text="Камера"
            android:textColor="@color/white"
            android:background="@drawable/button_background"
            android:layout_marginBottom="32dp"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_history"
                android:layout_width="110dp"
                android:layout_height="45dp"
                android:text="История"
                android:textColor="@color/white"
                android:background="@drawable/button_background"
                android:layout_marginEnd="10dp"
                android:textSize="12sp"/>

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/button_help"
                android:layout_width="110dp"
                android:layout_height="45dp"
                android:text="Справка"
                android:textColor="@color/white"
                android:background="@drawable/button_background"
                android:textSize="12sp"/>
        </LinearLayout>

        <TextView
            android:id="@+id/dev_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Разработала Петрусевич А. А. АС-66"
            android:textColor="@color/accent_neon_cyan"
            android:textAlignment="center"
            android:textSize="14sp"
            android:alpha="0.7" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
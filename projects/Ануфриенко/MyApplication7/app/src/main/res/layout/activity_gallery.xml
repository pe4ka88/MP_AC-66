<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Шапка -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="#CC000000"
        android:paddingStart="8dp"
        android:paddingEnd="12dp"
        android:paddingTop="10dp"
        android:paddingBottom="10dp">

        <Button
            android:id="@+id/btn_gallery_back"
            android:layout_width="wrap_content"
            android:layout_height="38dp"
            android:text="◀"
            android:textSize="16sp"
            android:textColor="@color/white"
            android:backgroundTint="#44FFFFFF"/>

        <TextView
            android:id="@+id/tv_counter"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="0 / 0"
            android:textColor="@color/white"
            android:textSize="16sp"
            android:textStyle="bold"
            android:gravity="center"/>

        <!-- Зум − -->
        <Button
            android:id="@+id/btn_zoom_out_g"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="−"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:backgroundTint="#44FFFFFF"
            android:padding="0dp"
            android:layout_marginEnd="4dp"/>

        <!-- Зум + -->
        <Button
            android:id="@+id/btn_zoom_in_g"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="@color/white"
            android:backgroundTint="#44FFFFFF"
            android:padding="0dp"/>
    </LinearLayout>

    <!-- Изображение — занимает всё свободное пространство -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <!-- Кнопка Назад — левый край, по центру -->
        <Button
            android:id="@+id/btn_prev"
            android:layout_width="48dp"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|start"
            android:layout_marginStart="4dp"
            android:text="‹"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:backgroundTint="#66000000"
            android:padding="0dp"
            android:elevation="4dp"/>

        <!-- Само фото — строго по центру, от края до края -->
        <ImageView
            android:id="@+id/iv_gallery"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:scaleType="fitCenter"
            android:adjustViewBounds="true"
            android:background="#000000"/>

        <!-- Кнопка Вперёд — правый край, по центру -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="48dp"
            android:layout_height="80dp"
            android:layout_gravity="center_vertical|end"
            android:layout_marginEnd="4dp"
            android:text="›"
            android:textSize="32sp"
            android:textColor="@color/white"
            android:backgroundTint="#66000000"
            android:padding="0dp"
            android:elevation="4dp"/>
    </FrameLayout>

    <!-- Нижняя полоса: имя файла и координаты -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#CC000000"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="8dp"
        android:paddingBottom="12dp">

        <TextView
            android:id="@+id/tv_img_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="—"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:gravity="center"/>

        <TextView
            android:id="@+id/tv_gallery_location"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="📍 ..."
            android:textColor="#AAFFFFFF"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginTop="2dp"/>
    </LinearLayout>

</LinearLayout>
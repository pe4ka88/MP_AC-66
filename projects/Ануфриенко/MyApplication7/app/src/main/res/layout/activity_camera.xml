<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:fitsSystemWindows="true">

    <!-- Превью камеры -->
    <SurfaceView
        android:id="@+id/surface_camera"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Верхняя панель: координаты и зум -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:background="#99000000">

        <TextView
            android:id="@+id/tv_cam_location"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📍 Координаты..."
            android:textSize="11sp"
            android:textColor="#CCFFFFFF"/>

        <TextView
            android:id="@+id/tv_zoom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Зум: 0×"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Нижняя панель управления -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:paddingTop="14dp"
        android:paddingBottom="22dp"
        android:background="#CC000000">

        <!-- Назад -->
        <Button
            android:id="@+id/btn_cam_back"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="◀ Назад"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#66FFFFFF"/>

        <View
            android:layout_width="0dp"
            android:layout_height="1dp"
            android:layout_weight="1"/>

        <!-- Зум − -->
        <Button
            android:id="@+id/btn_zoom_out"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="−"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44FFFFFF"
            android:layout_marginEnd="6dp"
            android:padding="0dp"/>

        <!-- Зум + -->
        <Button
            android:id="@+id/btn_zoom_in"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:text="+"
            android:textSize="22sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#44FFFFFF"
            android:layout_marginEnd="16dp"
            android:padding="0dp"/>

        <!-- Кнопка съёмки -->
        <Button
            android:id="@+id/btn_shot"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:text="●"
            android:textSize="32sp"
            android:textColor="#FFFFFF"
            android:backgroundTint="#CCDD2222"
            android:padding="0dp"/>

    </LinearLayout>

</RelativeLayout>
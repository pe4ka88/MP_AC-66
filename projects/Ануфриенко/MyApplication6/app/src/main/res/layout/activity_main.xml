<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingTop="36dp"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingBottom="16dp"
    android:background="#F5F5F5">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Медиаплеер (выполнен Ануфриенко М.А.)"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="#333333"
        android:gravity="center"
        android:paddingBottom="12dp"/>

    <!-- Кнопки выбора типа файла -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        android:layout_marginBottom="8dp">

        <Button
            android:id="@+id/buttonImage"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Фото"
            android:onClick="onClFile"
            android:backgroundTint="#4CAF50"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/buttonAudio"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:text="Аудио"
            android:onClick="onClFile"
            android:backgroundTint="#2196F3"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/buttonVideo"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Видео"
            android:onClick="onClFile"
            android:backgroundTint="#F44336"
            android:textColor="#FFFFFF"/>

    </LinearLayout>

    <!-- Имя выбранного файла -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Файл: "
            android:textSize="13sp"
            android:textColor="#555555"/>

        <TextView
            android:id="@+id/tvFileName"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="не выбран"
            android:textSize="13sp"
            android:textColor="#888888"
            android:ellipsize="middle"
            android:singleLine="true"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#DDDDDD"
        android:layout_marginBottom="8dp"/>

    <!-- ═══ Блок видео ═══════════════════════════════════ -->

    <!-- Переключатель реализаций -->
    <LinearLayout
        android:id="@+id/layoutVideoControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:layout_marginBottom="4dp">

        <TextView
            android:id="@+id/tvVideoMode"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Реализация: VideoView"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:paddingBottom="4dp"/>

        <Button
            android:id="@+id/btnSwitchImpl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Переключить на TextureView"
            android:onClick="onSwitchImpl"
            android:backgroundTint="#607D8B"
            android:textColor="#FFFFFF"
            android:textSize="13sp"/>
    </LinearLayout>

    <!-- Реализация 1: VideoView -->
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        android:background="#000000"/>

    <!-- Реализация 2: TextureView -->
    <TextureView
        android:id="@+id/textureView"
        android:layout_width="match_parent"
        android:layout_height="220dp"
        android:layout_marginBottom="4dp"
        android:visibility="gone"/>

    <!-- Управление TextureView-плеером -->
    <LinearLayout
        android:id="@+id/layoutTextureControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#FFFFFF"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <!-- Прогресс / перемотка -->
        <SeekBar
            android:id="@+id/seekBarVideo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="4dp"/>

        <!-- Время -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="6dp">

            <TextView
                android:id="@+id/tvVideoPosition"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0:00"
                android:textSize="12sp"
                android:textColor="#555555"/>

            <TextView
                android:id="@+id/tvVideoDuration"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="0:00"
                android:textSize="12sp"
                android:textColor="#555555"/>
        </LinearLayout>

        <!-- Кнопки Play / Pause -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnVideoPlay"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Play"
                android:onClick="onVideoPlay"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:enabled="false"/>

            <Button
                android:id="@+id/btnVideoPause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Пауза"
                android:onClick="onVideoPause"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:enabled="false"/>

        </LinearLayout>
    </LinearLayout>

    <!-- ═══ Блок аудио ═══════════════════════════════════ -->
    <LinearLayout
        android:id="@+id/layoutAudioControls"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone"
        android:background="#FFFFFF"
        android:padding="12dp"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/tvAudioStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Готов к воспроизведению"
            android:textSize="14sp"
            android:textColor="#555555"
            android:gravity="center"
            android:paddingBottom="12dp"/>

        <!-- Только Play и Пауза -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/start"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="Play"
                android:onClick="play"
                android:backgroundTint="#4CAF50"
                android:textColor="#FFFFFF"
                android:enabled="true"/>

            <Button
                android:id="@+id/pause"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Пауза"
                android:onClick="pause"
                android:backgroundTint="#FF9800"
                android:textColor="#FFFFFF"
                android:enabled="false"/>

        </LinearLayout>
    </LinearLayout>

    <!-- Подсказка при старте -->
    <LinearLayout
        android:id="@+id/layoutHint"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:padding="24dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Нажмите кнопку выше для выбора файла"
            android:textSize="16sp"
            android:textColor="#AAAAAA"
            android:gravity="center"/>
    </LinearLayout>

</LinearLayout>
<resources>

    <!-- Основная кнопка -->
    <style name="AppButton.Primary" parent="Widget.Material3.Button">
        <item name="backgroundTint">#D5356B</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">6dp</item>
        <item name="android:padding">10dp</item>
    </style>

    <!-- Нижние кнопки -->
    <style name="AppButton.Secondary" parent="Widget.Material3.Button">
        <item name="backgroundTint">#F22828</item>
        <item name="android:textColor">#FFFFFF</item>
        <item name="android:textSize">15sp</item>
        <item name="android:layout_margin">6dp</item>
        <item name="cornerRadius">16dp</item>
        <item name="elevation">6dp</item>
    </style>
    <!-- Поисковое поле -->
    <style name="SearchEditText">
        <item name="android:background">@drawable/search_bg</item>
        <item name="android:paddingStart">14dp</item>
        <item name="android:paddingEnd">14dp</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">#222222</item>
        <item name="android:textColorHint">#888888</item>
    </style>

</resources>
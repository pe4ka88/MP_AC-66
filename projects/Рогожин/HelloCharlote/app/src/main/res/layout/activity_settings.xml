<?xml version="1.0" encoding="utf-8"?>

<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_settings"
        android:scaleType="centerCrop"/>

    <LinearLayout
        android:layout_width="372dp"
        android:layout_height="659dp"
        android:layout_centerInParent="true"
        android:background="#66000000"
        android:orientation="vertical"
        android:padding="24dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:letterSpacing="0.1"
            android:fontFamily="@font/hello_charlotte"
            android:text="НАСТРОЙКИ"
            android:textColor="#FFFFFF"
            android:textSize="26sp" />

        <!-- Музыка -->
        <CheckBox
            android:id="@+id/checkMusic"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:button="@drawable/custom_checkbox"
            android:textColor="#FFFFFF"
            android:fontFamily="@font/hello_charlotte"
            android:text=" Музыка"/>

        <!-- Громкость -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:fontFamily="@font/hello_charlotte"
            android:text="Громкость"
            android:textColor="#FFFFFF" />

        <SeekBar
            android:id="@+id/seekVolume"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100" />

        <!-- Сложность -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:fontFamily="@font/hello_charlotte"
            android:text="Сложность"
            android:textColor="#FFFFFF" />

        <RadioGroup
            android:id="@+id/difficultyGroup"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <RadioButton
                android:id="@+id/diffEasy"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hello_charlotte"
                android:text="Легко"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF" />

            <RadioButton
                android:id="@+id/diffNormal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hello_charlotte"
                android:text="Нормально"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF" />

            <RadioButton
                android:id="@+id/diffHard"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="@font/hello_charlotte"
                android:text="Сложно"
                android:textColor="#FFFFFF"
                android:buttonTint="#FFFFFF" />

        </RadioGroup>

    </LinearLayout>
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:gravity="center"
        android:padding="8dp"
        android:text="© 2026 Рогожин А.С. АС-66"
        android:textColor="#000000"
        android:textSize="12sp" />
</RelativeLayout>
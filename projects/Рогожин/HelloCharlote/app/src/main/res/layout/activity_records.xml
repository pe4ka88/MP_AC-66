<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фон -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_records"
        android:scaleType="centerCrop" />

    <!-- Контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="top|center_horizontal"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Заголовок -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginBottom="20dp"
            android:fontFamily="@font/hello_charlotte"
            android:letterSpacing="0.1"
            android:text="РКЕОРДЫ"
            android:textColor="#261A1A"
            android:textSize="26sp" />

        <!-- Список рекордов -->
        <ScrollView
            android:layout_width="369dp"
            android:layout_height="650dp"
            android:layout_weight="1">

            <TextView
                android:id="@+id/recordsText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="20dp"
                android:fontFamily="@font/hello_charlotte"
                android:letterSpacing="0.1"
                android:text=""
                android:textColor="#261A1A"
                android:textSize="16sp" />
        </ScrollView>

        <!-- Кнопка "Начать сначала" -->
        <Button
            android:id="@+id/restartGameButton"
            style="@style/ButtonStyle"
            android:layout_width="295dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Начать сначала"
            android:textColor="#A61F1F" />
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="© 2026 Рогожин А.С. АС-66"
            android:textColor="#000000"
            android:textSize="12sp" />

    </LinearLayout>

</FrameLayout>

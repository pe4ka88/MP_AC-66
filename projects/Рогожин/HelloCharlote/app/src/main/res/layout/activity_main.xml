<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Фон -->
    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:src="@drawable/bg_main"
        android:scaleType="centerCrop" />

    <!-- Контент -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Статус и информация (текст друг под другом) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:layout_marginBottom="8dp">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Найдите все пары"
                android:textSize="14sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/hello_charlotte"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/scoreText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Счёт: 0"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/hello_charlotte"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/pairsCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Осталось: 0"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/hello_charlotte"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/timerText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Время: 60с"
                android:textSize="12sp"
                android:textColor="#FFFFFF"
                android:fontFamily="@font/hello_charlotte"/>
        </LinearLayout>

        <!-- ИГРОВОЕ ПОЛЕ -->
        <GridLayout
            android:id="@+id/gameField"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true"
            android:gravity="center" />

        <!-- КНОПКИ -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:padding="8dp">

                <Button
                    style="@style/ButtonStyle"
                    android:id="@+id/restartButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Заново"/>
                <Button
                    style="@style/ButtonStyle"
                    android:id="@+id/recordsButton"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Рекорды"/>

            </LinearLayout>

        </HorizontalScrollView>
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            android:gravity="center"
            android:padding="8dp"
            android:text="© 2026 Рогожин А.С. АС-66"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
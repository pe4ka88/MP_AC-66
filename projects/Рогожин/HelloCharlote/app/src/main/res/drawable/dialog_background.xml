<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">

    <!-- Фон диалога -->
    <solid android:color="#DD000000"/>

    <!-- Закруглённые углы -->
    <corners android:radius="16dp"/>

    <!-- Пиксельная белая рамка -->
    <stroke
        android:width="8dp"
        android:color="#FFFFFF"/>

    <!-- Внутренние отступы -->
    <padding
        android:left="8dp"
        android:top="8dp"
        android:right="8dp"
        android:bottom="8dp"/>
</shape>
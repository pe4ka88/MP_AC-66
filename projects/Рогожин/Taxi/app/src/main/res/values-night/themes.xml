<resources xmlns:tools="http://schemas.android.com/tools">

    <!-- Базовая тёмная тема -->
    <style name="Base.Theme.Taxi" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Можно здесь переопределять базовые цвета -->
    </style>

    <!-- Основная тема приложения -->
    <style name="Theme.Taxi" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Основные цвета -->
        <item name="colorPrimary">#FF4053</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="colorPrimaryContainer">#FF4053</item>
        <item name="colorOnPrimaryContainer">@color/text_on_primary</item>

        <!-- Фон окна -->
        <item name="android:windowBackground">@color/bg_dark</item>
        <item name="colorOnBackground">@color/text_light_d</item>

        <!-- Цвета карточек -->
        <item name="colorSurface">#565656</item>
        <item name="colorOnSurface">@color/text_light_d</item>
        <item name="colorSurfaceVariant">@color/surface_variant_dark</item>
        <item name="colorOnSurfaceVariant">@color/text_light_variant</item>

        <!-- Акценты -->
        <item name="colorSecondary">@color/accent_variant</item>
        <item name="colorOnSecondary">@color/text_on_primary</item>

        <!-- Стили кнопок и карточек можно оставить по умолчанию -->
        <item name="materialButtonStyle">@style/SoftButton</item>
        <item name="cardViewStyle">@style/SoftCard</item>

    </style>

</resources>
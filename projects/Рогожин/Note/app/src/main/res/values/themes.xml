<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.Note" parent="Theme.Material3.DayNight.NoActionBar">

        <!-- Основные цвета -->
        <item name="colorPrimary">@color/md_primary</item>
        <item name="colorOnPrimary">@color/md_on_primary</item>

        <item name="colorSecondary">@color/md_secondary</item>
        <item name="colorOnSecondary">@color/md_on_secondary</item>

        <!-- Поверхности -->
        <item name="colorSurface">@color/md_surface</item>
        <item name="colorOnSurface">@color/md_on_surface</item>

        <!-- Статус бар -->
        <item name="android:statusBarColor">?attr/colorSurface</item>

        <!-- Фон приложения -->
        <item name="android:colorBackground">?attr/colorSurface</item>

        <!-- Стиль карточек -->
        <item name="materialCardViewStyle">@style/AppCardStyle</item>

        <!-- Toolbar без тени -->
        <item name="toolbarStyle">@style/AppToolbarStyle</item>

        <item name="textInputStyle">@style/Widget.Material3.TextInputLayout.FilledBox</item>
        <item name="textAppearanceHeadline6">@style/TextAppearance.Material3.HeadlineSmall</item>
        <item name="textAppearanceBody1">@style/TextAppearance.Material3.BodyMedium</item>

        <!-- Кнопки Material3 -->
        <item name="materialButtonStyle">@style/Widget.Material3.Button</item>
    </style>

    <!-- Карточки -->
    <style name="AppCardStyle" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
    </style>

    <!-- Toolbar -->
    <style name="AppToolbarStyle" parent="Widget.Material3.Toolbar">
        <item name="backgroundTint">?attr/colorSurface</item>
        <item name="titleTextColor">?attr/colorOnSurface</item>
        <item name="elevation">0dp</item>
    </style>

</resources>
<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/gradient_bg"
    android:padding="24dp"
    tools:context=".ThirdActivity">

    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="Маршрут"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <EditText
        android:id="@+id/etStreet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:background="@drawable/edit_text_bg"
        android:hint="@string/street_hint"
        android:inputType="text"
        android:textColor="@android:color/white"
        android:textColorHint="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        android:autofillHints="postalAddress" />

    <LinearLayout
        android:id="@+id/llSourceHouseFlat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etStreet">

        <EditText
            android:id="@+id/etHouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/house_hint"
            android:inputType="text"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:autofillHints="postalAddress" />

        <EditText
            android:id="@+id/etFlat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/flat_hint"
            android:inputType="text"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:autofillHints="postalAddress" />
    </LinearLayout>

    <EditText
        android:id="@+id/etDestStreet"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:background="@drawable/edit_text_bg"
        android:hint="@string/dest_street_hint"
        android:inputType="text"
        android:textColor="@android:color/white"
        android:textColorHint="#CCFFFFFF"
        app:layout_constraintTop_toBottomOf="@id/llSourceHouseFlat"
        android:autofillHints="postalAddress" />

    <LinearLayout
        android:id="@+id/llDestHouseFlat"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:orientation="horizontal"
        app:layout_constraintTop_toBottomOf="@id/etDestStreet">

        <EditText
            android:id="@+id/etDestHouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/dest_house_hint"
            android:inputType="text"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:autofillHints="postalAddress" />

        <EditText
            android:id="@+id/etDestFlat"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="6dp"
            android:background="@drawable/edit_text_bg"
            android:hint="@string/dest_flat_hint"
            android:inputType="text"
            android:textColor="@android:color/white"
            android:textColorHint="#CCFFFFFF"
            android:autofillHints="postalAddress" />
    </LinearLayout>

    <Button
        android:id="@+id/btnOk"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="32dp"
        android:backgroundTint="#039BE5"
        android:padding="12dp"
        android:text="@string/ok_button"
        android:textAllCaps="false"
        android:textSize="18sp"
        app:cornerRadius="25dp"
        app:layout_constraintTop_toBottomOf="@id/llDestHouseFlat" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:text="@string/copyright"
        android:textColor="#80FFFFFF"
        android:textSize="12sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
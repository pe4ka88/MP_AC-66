<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/tvUpdateHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Осовец Арсений | АС-66"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:paddingBottom="16dp" />

    <EditText
        android:id="@+id/etUpdateId"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Номер заметки (id)"
        android:inputType="number" />

    <EditText
        android:id="@+id/etUpdateDescription"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:hint="Новое описание"
        android:inputType="text"
        android:layout_marginTop="8dp" />

    <Button
        android:id="@+id/btnUpdate"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нажимает Осовец"
        android:layout_marginTop="16dp" />

    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <TextView
        android:id="@+id/tvUpdateFooter"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Разработал: Осовец Арсений, АС-66"
        android:textSize="14sp"
        android:gravity="center"
        android:paddingTop="8dp" />

</LinearLayout>

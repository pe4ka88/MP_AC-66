<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_glass_card"
    android:orientation="vertical"
    android:padding="14dp">

    <TextView
        android:id="@+id/authorNameText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/author_full_name"
        android:textColor="@color/ink_900"
        android:textSize="16sp"
        android:textStyle="bold" />

    <Button
        android:id="@+id/authorActionButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/bg_glass_button"
        android:minHeight="0dp"
        android:paddingLeft="12dp"
        android:paddingTop="8dp"
        android:paddingRight="12dp"
        android:paddingBottom="8dp"
        android:text="@string/author_button"
        android:textAllCaps="false"
        android:textColor="@color/ink_900" />

    <TextView
        android:id="@+id/authorSignatureText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="@string/author_signature"
        android:textColor="@color/ink_700"
        android:textSize="13sp" />
</LinearLayout>

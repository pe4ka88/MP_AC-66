<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="8dp"
    android:background="@drawable/bg_glass_button"
    android:orientation="vertical"
    android:padding="10dp">

    <TextView
        android:id="@+id/textHistoryModule"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/ink_900"
        android:textSize="15sp"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/textHistoryAction"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/ink_700"
        android:textSize="14sp" />

    <TextView
        android:id="@+id/textHistoryTime"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:textColor="@color/ink_500"
        android:textSize="12sp" />

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    tools:context=".OrderActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/order_title"
            android:textSize="24sp"
            android:textStyle="bold" />

        <Button
            android:id="@+id/btnTaskInfo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_info_short"
            android:textSize="12sp"
            style="@style/Widget.Material3.Button.TextButton" />
    </LinearLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/author_developed_by"
        android:textSize="12sp"
        android:textColor="#888888"
        android:layout_marginBottom="12dp" />

    <TextView
        android:id="@+id/tvUserName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginBottom="8dp"
        tools:text="Name: Ivan Ivanov" />

    <TextView
        android:id="@+id/tvUserPhone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="18sp"
        android:layout_marginBottom="20dp"
        tools:text="Phone: +375291234567" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="?android:attr/listDivider"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/route_label"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvRoute"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="15sp"
        android:minHeight="60dp"
        android:background="@drawable/route_bg"
        android:padding="12dp"
        android:layout_marginBottom="20dp"
        tools:text="" />

    <Button
        android:id="@+id/btnSetPath"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_set_path"
        android:textSize="16sp"
        android:layout_marginBottom="12dp"
        style="@style/Widget.Material3.Button.TonalButton" />

    <Button
        android:id="@+id/btnCallTaxi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_call_taxi"
        android:textSize="16sp"
        android:enabled="false" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/author_footer"
        android:textSize="11sp"
        android:textColor="#999999"
        android:gravity="center"
        android:layout_marginTop="16dp" />

</LinearLayout>

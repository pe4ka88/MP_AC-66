<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:padding="12dp"
    android:background="#FAFAFA"
    android:layout_marginBottom="4dp">

    <!-- Статус игры -->
    <ImageView
        android:id="@+id/historyStatusIcon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/star_big_on"
        android:layout_gravity="center_vertical"/>

    <!-- Информация об игре -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/historyDate"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01.01 12:00"
                android:textSize="12sp"
                android:textColor="#757575"/>

            <TextView
                android:id="@+id/historyMode"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4x4 • Пары"
                android:textSize="12sp"
                android:textColor="#757575"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <TextView
            android:id="@+id/historyResult"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Победа!"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#4CAF50"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/historyStats"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Время: 01:23 • Ходы: 15"
            android:textSize="12sp"
            android:textColor="#424242"
            android:layout_marginTop="2dp"/>

    </LinearLayout>

</LinearLayout>

<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="TextAppearance.Lab6.Hero" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.02</item>
    </style>

    <style name="TextAppearance.Lab6.Section" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.Lab6.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif</item>
    </style>

    <style name="TextAppearance.Lab6.Subtitle" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:lineSpacingExtra">2dp</item>
    </style>

    <style name="TextAppearance.Lab6.Data" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/api_text</item>
        <item name="android:fontFamily">monospace</item>
    </style>

    <style name="Widget.Lab6.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/card_background</item>
        <item name="cardCornerRadius">24dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>

    <style name="Widget.Lab6.Button.Primary" parent="Widget.Material3.Button">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="backgroundTint">@color/brand_primary</item>
        <item name="android:textColor">@color/brand_on_primary</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">50dp</item>
    </style>

    <style name="Widget.Lab6.Button.Secondary" parent="Widget.Material3.Button.OutlinedButton">
        <item name="android:textAllCaps">false</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="strokeColor">@color/card_stroke</item>
        <item name="cornerRadius">14dp</item>
        <item name="android:minHeight">50dp</item>
    </style>

    <style name="Widget.Lab6.Button.Small" parent="Widget.Material3.Button.TonalButton">
        <item name="android:textAllCaps">false</item>
        <item name="backgroundTint">@color/surface_subtle</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="cornerRadius">12dp</item>
    </style>

    <style name="Widget.Lab6.Chip" parent="Widget.Material3.Chip.Assist">
        <item name="chipBackgroundColor">@color/surface_subtle</item>
        <item name="android:textColor">@color/text_primary</item>
        <item name="chipStrokeColor">@color/card_stroke</item>
        <item name="chipStrokeWidth">1dp</item>
        <item name="android:textStyle">bold</item>
    </style>

</resources>